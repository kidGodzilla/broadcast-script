# Postgres bootstrap config. The username MUST stay `broadcast` (the healthcheck
# and the app's DATABASE_USERNAME both expect it). Use a strong password and reuse
# the SAME value for the app's DATABASE_PASSWORD.
POSTGRES_USER=broadcast
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_MULTIPLE_DATABASES=broadcast_primary_production,broadcast_queue_production,broadcast_cable_production
