# Broadcast app configuration for Dokku.
#
# These are consumed via `dokku config:set` (see SETUP.md), NOT mounted as a file.
# Generate secrets with: openssl rand -hex 64   (SECRET_KEY_BASE)
#                        openssl rand -hex 16   (each encryption key below)
# Keep DATABASE_PASSWORD identical to POSTGRES_PASSWORD in postgres/.env.

RAILS_ENV=production
SECRET_KEY_BASE=replace-with-openssl-rand-hex-64

# Database — single host/user/password; Broadcast derives the 3 db names itself.
# DATABASE_HOST is the Postgres container's name on the shared `broadcast` network.
DATABASE_HOST=broadcast-postgres
DATABASE_USERNAME=broadcast
DATABASE_PASSWORD=replace-with-same-as-postgres-password

# Your public domain. Used for link generation / host authorization even though
# Dokku (not the app) terminates TLS in this setup.
TLS_DOMAIN=broadcast.example.com

# Your Broadcast license key.
LICENSE_KEY=replace-with-your-license-key

# Active Record encryption keys — REQUIRED (encrypts API keys & other secrets).
# The vendor's root installer auto-generates these; in manual/Dokku mode you must
# supply them yourself. Generate three independent 32-char hex values.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace-with-openssl-rand-hex-16
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace-with-openssl-rand-hex-16
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace-with-openssl-rand-hex-16

# NOTE: intentionally omitted vs. the managed install —
#   BROADCAST_MANAGED  (managed-host only; enables phone-home/host-control features)
#   STORAGE_PATH=/rails/ssl  (only used by the app's built-in Thruster TLS, which
#                             we bypass — Dokku handles certs)
